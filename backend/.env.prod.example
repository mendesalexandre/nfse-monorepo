# Cópia: backend/.env.prod (NÃO commit — é gitignored)
APP_NAME="NFSe Emissor"
APP_ENV=production
APP_KEY=  # gerar: docker compose -f docker-compose.prod.yml exec app php artisan key:generate
APP_DEBUG=false
APP_URL=https://SEU_DOMINIO
APP_TIMEZONE=America/Cuiaba
APP_LOCALE=pt_BR

# Database
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=nfse
DB_USERNAME=nfse
DB_PASSWORD=GERAR_SENHA_FORTE

# Redis (com password obrigatória em prod)
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=GERAR_SENHA_FORTE

# Cache, Session, Queue
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DOMAIN=SEU_DOMINIO
SANCTUM_STATEFUL_DOMAINS=SEU_DOMINIO

# Reverb (WebSocket)
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=GERAR
REVERB_APP_KEY=GERAR
REVERB_APP_SECRET=GERAR
REVERB_HOST=SEU_DOMINIO
REVERB_PORT=443
REVERB_SCHEME=https

# OpenSSL legacy provider — DPS SDK NFSe exige rsa-sha1
OPENSSL_CONF=/etc/ssl/openssl-sha1.cnf

# Cert PFX (volume mount em /opt/certs ou storage/certs/)
PFX_PATH=/var/www/html/storage/certs/cartorio_sinop.pfx
